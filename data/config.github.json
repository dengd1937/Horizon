{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com/v1",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 4,
    "enrichment_concurrency": 2,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "TechCrunch AI",
        "url": "https://techcrunch.com/category/artificial-intelligence/feed/",
        "enabled": false,
        "category": "ai-news"
      },
      {
        "name": "The Verge AI",
        "url": "https://www.theverge.com/rss/ai-artificial-intelligence/index.xml",
        "enabled": false,
        "category": "ai-news"
      },
      {
        "name": "Ars Technica AI",
        "url": "https://arstechnica.com/ai/feed/",
        "enabled": false,
        "category": "ai-news"
      }
    ],
    "reddit": {
      "enabled": false,
      "fetch_comments": 5,
      "subreddits": []
    },
    "github": [],
    "ossinsight": {
      "enabled": false
    },
    "twitter": {
      "enabled": true,
      "mode": "playwright",
      "users": [
        "dotey",
        "karpathy",
        "Zai_org",
        "AnthropicAI",
        "OpenAI",
        "Alibaba_Qwen",
        "deepseek_ai"
      ],
      "fetch_limit": 20,
      "fetch_reply_text": true,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "ai": {
        "name": "AI / LLM / Agent",
        "limit": 12,
        "categories": [
          "ai-news",
          "ai-tools",
          "machine-learning",
          "llm"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 5
  },
  "email": {
    "enabled": true,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_enabled": false,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "2736883878@qq.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily"
  },
  "webhook": {
    "enabled": false
  },
  "site": {
    "enabled": true,
    "output_dir": "data/site",
    "base_url": "https://daily.signalfeed.site/d/${COS_SITE_PREFIX}",
    "deploy_command": "coscli sync data/site/ cos://signalfeed-1257788828/d/${COS_SITE_PREFIX}/ -r --delete --force -i \"$COS_SECRET_ID\" -k \"$COS_SECRET_KEY\" -e cos.ap-hongkong.myqcloud.com",
    "max_media_mb": 50
  }
}
